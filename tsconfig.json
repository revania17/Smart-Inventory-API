{
    "include": [
        "src/**/*.ts"
    ],
    "compilerOptions": {
        "target": "ES6",
        "module": "Node16",
        "moduleResolution": "Node16",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    }
}
